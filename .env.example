# Sarvam AI (server-only; never expose to the browser)
SARVAM_API_KEY=
# The server loads this value directly from `.env` via dotenv in both local and
# Databricks Node runtimes.

# Optional overrides (defaults: sarvam-30b router, sarvam-105b heavy)
# SARVAM_MODEL_ROUTER=sarvam-30b
# SARVAM_MODEL_HEAVY=sarvam-105b
