# Sarvam AI (server-only; never expose to the browser)
SARVAM_API_KEY=
# Python FastAPI backend loads this value from `.env`.
# Frontend can point to the backend with VITE_API_BASE_URL when needed.
# VITE_API_BASE_URL=http://localhost:8000

# Optional override (defaults to sarvam-105b)
# SARVAM_MODEL=sarvam-105b
